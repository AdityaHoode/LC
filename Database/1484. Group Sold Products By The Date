select
    sell_date,
    count(distinct product) as num_sold,
    group_concat(
        distinct product
        order by
            product separator ','
    ) as products
from
    activities
group by
    sell_date
order by
    sell_Date 
    
-- R1
select
    sell_date,
    count(*) as num_sold,
    group_concat(
        product
        order by
            product,
            ','
    ) as products
from
    (
        select
            distinct sell_date,
            product
        from
            activities
    ) a
group by
    sell_date
order by
    sell_date