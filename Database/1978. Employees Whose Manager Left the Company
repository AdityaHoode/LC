select 
a.employee_id
from
employees a
left join employees b
on a.manager_id=b.employee_id
where b.employee_id is null
and a.manager_id is not null
and a.salary < 30000
order by a.employee_id

-- R1
select 
employee_id
from employees
where manager_id not in (
    select employee_id as manager_id from employees
)
and salary < 30000
order by employee_id

select 
employee_id
from employees a
where not exists (
    select 1 from employees b where b.employee_id=a.manager_id
)
and a.manager_id IS NOT NULL
and salary < 30000
order by employee_id