select person_name from (
    select
    *,
    sum(weight) over (order by turn) as cumsum
    from queue
) a
where cumsum<=1000
order by turn desc
limit 1

-- R1

with base as (
    select
    *,
    sum(weight) over (order by turn) as cs
    from queue
),
c1 as (
    select
    *,
    row_number() over (order by turn desc) as rn
    from base 
    where cs<=1000
)
select person_name from c1 where rn=1
