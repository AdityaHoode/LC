select
sample_id,
dna_sequence,
species,
case when substring(dna_sequence,1,3)='ATG' then 1 else 0 end as has_start,
case when substring(dna_sequence,length(dna_sequence)-2) in ('TAA', 'TAG', 'TGA') then 1 else 0 end as has_stop,
case when dna_sequence like '%ATAT%' then 1 else 0 end as has_atat,
case when dna_sequence like '%GGG%' then 1 else 0 end as has_ggg
from
samples
order by sample_id

-- where 1=1
-- and substring(dna_sequence,1,3)='ATG'
-- and substring(dna_sequence,length(dna_sequence)-2) in ('TAA', 'TAG', 'TGA')
-- and dna_sequence like '%ATAT%'
-- and dna_sequence like '%GGG%'

-- R1
with base as (
    select
    *,
    case when regexp_like(dna_sequence, '^ATG') then 1 else 0 end as has_start,
    case when regexp_like(dna_sequence, '(TAA|TAG|TGA)$') then 1 else 0 end as has_stop,
    case when regexp_like(dna_sequence, '(ATAT)+') then 1 else 0 end as has_atat,
    case when regexp_like(dna_sequence, '[G]{3}') then 1 else 0 end as has_ggg
    from samples
)
select
*
from base
where 1=1
and not has_start
or not has_stop
or not has_atat
or not has_ggg
order by sample_id