CREATE FUNCTION getNthHighestSalary(N INT) RETURNS INT
BEGIN
    DECLARE offset_val INT;
    SET offset_val=N-1;
    RETURN (
            select
            distinct salary
            from 
            employee
            order by salary desc
            limit 1 offset offset_val
    );
END

-- R1
CREATE FUNCTION getNthHighestSalary(N INT) RETURNS INT
BEGIN
  SET N=N-1;
  RETURN (
        select 
        salary
        from employee
        group by salary
        order by salary desc
        limit 1 offset N
  );
END