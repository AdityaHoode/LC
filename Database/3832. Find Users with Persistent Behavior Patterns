with b1 as (
    select
    *,
    count(*) over (partition by user_id, action) as cnt,
    datediff(action_date,lag(action_date,1,action_date) over (partition by user_id, action order by action_date)) as gap_days
    from activity
),
b2 as (
    select 
    *
    from b1
    where cnt>=5
),
b3 as (
    select 
    *
    from b2 a
    where not exists (
        select 
        1
        from b2 b
        where a.user_id=b.user_id 
        group by b.user_id
        having max(gap_days)>1
    )
)
select 
user_id,
max(action) as action,
max(cnt) as streak_length,
min(action_date) as start_date,
max(action_date) as end_date
from b3
group by user_id
order by 3 desc, 1

WITH base AS (
    SELECT *,
           ROW_NUMBER() OVER (PARTITION BY user_id, action ORDER BY action_date) AS rn
    FROM activity
),
grp AS (
    SELECT *,
           DATE_SUB(action_date, INTERVAL rn DAY) AS grp_key
    FROM base
),
streaks AS (
    SELECT 
        user_id,
        action,
        COUNT(*) AS streak_length,
        MIN(action_date) AS start_date,
        MAX(action_date) AS end_date
    FROM grp
    GROUP BY user_id, action, grp_key
    HAVING COUNT(*) >= 5
),
ranked AS (
    SELECT *,
           ROW_NUMBER() OVER (PARTITION BY user_id ORDER BY streak_length DESC) AS rnk
    FROM streaks
)
SELECT 
    user_id,
    action,
    streak_length,
    start_date,
    end_date
FROM ranked
WHERE rnk = 1
ORDER BY streak_length DESC, user_id;
