with base as (
    select 
    *,
    row_number() over (partition by user_id order by event_date desc) as rn,
    (
        first_value(monthly_amount) over (partition by user_id order by event_date desc)
        /
        first_value(monthly_amount) over (partition by user_id order by event_date)
    )*100 < 50 as plan_revenue,
    datediff(
        max(event_date) over (partition by user_id)
        ,min(event_date) over (partition by user_id)
    ) as days_as_subscriber,
    max(monthly_amount) over (partition by user_id) as max_historical_amount 
    from subscription_events
    where user_id in (
        select user_id 
        from subscription_events
        group by user_id
        having sum(case when event_type='downgrade' then 1 else 0 end)>=1
        and datediff(max(event_date),min(event_date))>=60
    )
),
c1 as (
    select *
    from base
    where user_id not in (
        select user_id 
        from base
        where (rn=1 and event_type='cancel')
        or plan_revenue = 0
    )
),
c2 as (
    select 
    *,
    row_number() over (partition by user_id order by event_date desc) as rn2
    from c1
)
select 
user_id,
plan_name as current_plan,
monthly_amount as current_monthly_amount,
max_historical_amount,
days_as_subscriber 
from c2 where rn2=1
order by days_as_subscriber desc, user_id

-- R1
with base as (
    select 
    *
    from subscription_events a
    where not exists (
        select
        1
        from (
            select 
            *,
            last_value(event_type) over (partition by user_id order by event_date) as lv
            from subscription_events 
        ) b
        where a.user_id=b.user_id and lv='cancel'
    )
),
c1 as (
    select 
    *,
    first_value(monthly_amount) over (partition by user_id order by event_date desc) as cp,
    max(monthly_amount) over (partition by user_id order by event_date rows between unbounded preceding and unbounded following) as ma,
    datediff(
        max(event_date) over (partition by user_id),
        min(event_date) over (partition by user_id)
    ) as days,
    first_value(plan_name) over (partition by user_id order by event_date desc) as current_plan
    from base a
    where exists (
        select 
        *
        from (
            select *, 
            group_concat(event_type separator ',') as gstr 
            from base
            group by user_id
        ) b
        where a.user_id=b.user_id and gstr like '%downgrade%'
    )
)
select 
user_id,
current_plan,
cp as current_monthly_amount,
ma as max_historical_amount,
days as days_as_subscriber 
from c1
where 0.5*ma>cp and days>=60
group by user_id
order by 5 desc, 1 asc