select 
transaction_date,
coalesce(sum(
    case
        when amount%2<>0 then amount
    end
),0) as odd_sum,
coalesce(sum(
    case
        when amount%2=0 then amount
    end
),0) as even_sum
from
transactions
group by transaction_date
order by transaction_date

-- R1
select
transaction_date,
sum(case when amount%2<>0 then amount else 0 end) as odd_sum,
sum(case when amount%2=0 then amount else 0 end) as even_sum
from transactions
group by transaction_date
order by transaction_date